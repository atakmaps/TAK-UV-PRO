<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1B1B1B"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:id="@+id/header_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BTECH Relay"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <!-- ==================== CONNECTION ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONNECTION"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/status_dot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="#FFFF0000"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Disconnected"
                    android:textColor="#FFFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/device_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFAAAAAA"
                android:textSize="12sp"
                android:paddingTop="2dp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp">

                <Button
                    android:id="@+id/btn_scan"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="SCAN &amp; CONNECT"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="#FF00BCD4" />

                <Button
                    android:id="@+id/btn_disconnect"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="DISCONNECT"
                    android:textSize="12sp"
                    android:enabled="false"
                    android:backgroundTint="#FFF44336" />
            </LinearLayout>

        </LinearLayout>

        <!-- ==================== ENCRYPTION ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ENCRYPTION"
                android:textColor="#FFFF9800"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AES-256 Encryption"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_encryption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/passphrase_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp"
                android:visibility="gone">

                <EditText
                    android:id="@+id/edit_passphrase"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:hint="Shared passphrase"
                    android:textColor="#FFFFFFFF"
                    android:textColorHint="#FF666666"
                    android:textSize="13sp"
                    android:background="#FF1B1B1B"
                    android:padding="8dp"
                    android:inputType="textPassword"
                    android:singleLine="true"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btn_set_passphrase"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="SET"
                    android:textSize="11sp"
                    android:backgroundTint="#FFFF9800"
                    android:minWidth="60dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_encryption_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="All radios must share the same passphrase"
                android:textColor="#FF888888"
                android:textSize="11sp"
                android:paddingTop="4dp" />
        </LinearLayout>

        <!-- ==================== RELAY SETTINGS ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RELAY"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PLI / SA to Radio"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_cot_relay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Forwards CoT, CASEVAC, markers over radio"
                android:textColor="#FF888888"
                android:textSize="11sp"
                android:paddingTop="1dp"
                android:paddingBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="GeoChat to Radio"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switch_chat_relay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bridges ATAK GeoChat with radio network"
                android:textColor="#FF888888"
                android:textSize="11sp"
                android:paddingTop="1dp"
                android:paddingBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="GPS Beacon Interval"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_beacon_interval"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60s"
                    android:textColor="#FF00BCD4"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ==================== RADIO INFO ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RADIO"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Callsign:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_callsign"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="OPENRL"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Team Color:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_team_color"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cyan"
                    android:textColor="#FF00BCD4"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Contacts:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_contacts"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 active"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Packets TX / RX:"
                    android:textColor="#FFAAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_packets"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 / 0"
                    android:textColor="#FFFFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ==================== ACTIONS ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ACTIONS"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_send_beacon"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Send Beacon"
                    android:textSize="11sp"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="#FF455A64" />

                <Button
                    android:id="@+id/btn_send_ping"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Send Ping"
                    android:textSize="11sp"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="#FF455A64" />

                <Button
                    android:id="@+id/btn_settings"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Settings"
                    android:textSize="11sp"
                    android:backgroundTint="#FF455A64" />
            </LinearLayout>
        </LinearLayout>

        <!-- ==================== LOG ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF2D2D2D"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LOG"
                android:textColor="#FF00BCD4"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/text_log"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:text=""
                android:textColor="#FF888888"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:scrollbars="vertical"
                android:gravity="bottom"
                android:background="#FF1B1B1B"
                android:padding="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
