    <path
        android:pathData="M24,12 L24,28"
        android:strokeColor="#FF00BCD4"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!-- Radio waves left -->
    <path
        android:pathData="M16,18 Q18,24 16,30"
        android:strokeColor="#FF00BCD4"
        android:strokeWidth="2"
        android:fillColor="#00000000"
        android:strokeLineCap="round" />

    <!-- Radio waves right -->
    <path
        android:pathData="M32,18 Q30,24 32,30"
        android:strokeColor="#FF00BCD4"
        android:strokeWidth="2"
        android:fillColor="#00000000"
        android:strokeLineCap="round" />

    <!-- Base dot -->
    <path
        android:pathData="M24,32 m-3,0 a3,3 0,1 1,6 0 a3,3 0,1 1,-6 0"
        android:fillColor="#FF00BCD4" />

    <!-- Arrow/relay indicator -->
    <path
        android:pathData="M12,24 L8,24 M40,24 L36,24"
        android:strokeColor="#FF00BCD4"
        android:strokeWidth="2"
        android:strokeLineCap="round" />
