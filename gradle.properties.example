# Gradle properties for BTECH Relay ATAK Plugin
# The repository includes a committed `gradle.properties` with shared flags.
# For the JDK path on your machine, merge a line such as org.gradle.java.home below
# into `gradle.properties`, or set JAVA_HOME to JDK 17.

org.gradle.jvmargs=-Xmx2048m
android.useAndroidX=true

# JDK 17 is required by Android Gradle Plugin 8.x.
# Update this path to match your JDK 17 installation, or remove this line
# if JAVA_HOME already points to JDK 17.
org.gradle.java.home=C:\\Program Files\\Eclipse Adoptium\\jdk-17.0.18.8-hotspot
